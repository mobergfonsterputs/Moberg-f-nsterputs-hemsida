# Kopiera till .env för lokal Netlify Dev (kopiera aldrig .env till Git).
# I Netlify: Site settings → Environment variables → lägg till samma nycklar.

# Mapbox: hemlig server-token (URL-begränsad token rekommenderas).
# Skapa token på https://account.mapbox.com/ — begränsa till din produktionsdomän.
MAPBOX_API_TOKEN=

# Admininloggning (minst 8 tecken). Endast servern jämför lösenordet.
ADMIN_PASSWORD=
